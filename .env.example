# URL externa del instalador (opcional). Si no se define, se usa /api/download/launcher
# NEXT_PUBLIC_LAUNCHER_DOWNLOAD_URL=https://tu-cdn.com/CraftLauncher-Setup.exe

# Ruta local al .exe (servidor). Por defecto busca en packages/launcher/release-out/
# LAUNCHER_INSTALLER_PATH=C:\ruta\CraftLauncher Setup 0.1.0.exe

# Admin API — backend de cuentas (mismo que el launcher)
NEXT_PUBLIC_ADMIN_API_URL=http://localhost:3000
ADMIN_API_URL=http://localhost:3000

# En producción con Railway:
# NEXT_PUBLIC_ADMIN_API_URL=https://craftlauncher-desktop-production.up.railway.app
# ADMIN_API_URL=https://craftlauncher-desktop-production.up.railway.app
